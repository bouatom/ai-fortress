# ── REQUIRED: SE must provide these ──────────────────────────────────────────
V1_API_KEY=                    # Vision One API key (TMV1-Bearer token)
TMAS_API_KEY=                  # TMAS artifact scanner API key
V1_REGION=us-1                 # Vision One region: us-1 | eu-1 | ap-1 | jp-1

# ── OPTIONAL: Defaults work out of the box ────────────────────────────────────
LLM_PROVIDER=ollama            # Default: ollama (local). Alt: openai
OLLAMA_MODEL=llama3.1          # Ollama model (pulled on first start, ~4GB)
OPENAI_API_KEY=                # Only required if LLM_PROVIDER=openai
PORT=3001                      # Web UI port

# ── NOTES ─────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in V1_API_KEY + TMAS_API_KEY
# 2. Run: docker compose up -d
# 3. First start downloads the Ollama model (~4GB) — takes a few minutes
# 4. Open http://localhost:3001 in your browser
#
# GPU note: GPU acceleration is auto-detected. CPU-only mode works but is slower.
# Recommend: t3.xlarge (CPU) or g4dn.xlarge (GPU) on AWS
